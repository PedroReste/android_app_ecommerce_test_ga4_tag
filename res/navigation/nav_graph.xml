<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:id="@+id/nav_graph" app:startDestination="@id/homeFragment">

    <!-- ══════════════════════════════════════════ -->
    <!-- Tela A: Home -->
    <!-- ══════════════════════════════════════════ -->
    <fragment android:id="@+id/homeFragment" android:name="com.example.ecommercetaggingapp.ui.home.HomeFragment" android:label="TechStore" tools:layout="@layout/fragment_home">

        <action android:id="@+id/action_homeFragment_to_productFragment" app:destination="@id/productFragment" app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left" app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />

        <action android:id="@+id/action_homeFragment_to_cartFragment" app:destination="@id/cartFragment" app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left" app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- ══════════════════════════════════════════ -->
    <!-- Tela B: Detalhe do Produto -->
    <!-- ══════════════════════════════════════════ -->
    <fragment android:id="@+id/productFragment" android:name="com.example.ecommercetaggingapp.ui.product.ProductFragment" android:label="Detalhes" tools:layout="@layout/fragment_product">

        <argument android:name="productId" app:argType="string" />

        <action android:id="@+id/action_productFragment_to_cartFragment" app:destination="@id/cartFragment" app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left" app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- ══════════════════════════════════════════ -->
    <!-- Tela C: Carrinho -->
    <!-- ══════════════════════════════════════════ -->
    <fragment android:id="@+id/cartFragment" android:name="com.example.ecommercetaggingapp.ui.cart.CartFragment" android:label="Carrinho" tools:layout="@layout/fragment_cart">

        <action android:id="@+id/action_cartFragment_to_successFragment" app:destination="@id/successFragment" app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left" app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- ══════════════════════════════════════════ -->
    <!-- Tela D: Sucesso -->
    <!-- ══════════════════════════════════════════ -->
    <fragment android:id="@+id/successFragment" android:name="com.example.ecommercetaggingapp.ui.success.SuccessFragment" android:label="Pedido Confirmado" tools:layout="@layout/fragment_success">

        <argument android:name="orderId" app:argType="string" />

        <action android:id="@+id/action_successFragment_to_homeFragment" app:destination="@id/homeFragment" app:popUpTo="@id/homeFragment" app:popUpToInclusive="true" app:enterAnim="@anim/slide_in_left" app:exitAnim="@anim/slide_out_right" />
    </fragment>

</navigation>
