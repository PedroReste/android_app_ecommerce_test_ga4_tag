<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="4dp" android:paddingVertical="8dp">

    <!-- Ícone -->
    <ImageView android:id="@+id/ivOrderItemIcon" android:layout_width="28dp" android:layout_height="28dp" android:contentDescription="Produto" android:src="@drawable/ic_smartphone" app:tint="@color/orange_primary" xmlns:app="http://schemas.android.com/apk/res-auto" />

    <!-- Nome e quantidade -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:orientation="vertical">

        <TextView android:id="@+id/tvOrderItemName" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold" />

        <TextView android:id="@+id/tvOrderItemQty" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="@color/text_secondary" android:textSize="12sp" />

    </LinearLayout>

    <!-- Preço -->
    <TextView android:id="@+id/tvOrderItemPrice" android:layout_width="90dp" android:layout_height="wrap_content" android:gravity="end" android:textColor="@color/orange_primary" android:textSize="13sp" android:textStyle="bold" />

</LinearLayout>
