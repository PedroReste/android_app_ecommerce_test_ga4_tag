<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/background_dark" android:fillViewport="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingBottom="40dp">

        <!-- Ícone de sucesso -->
        <ImageView android:id="@+id/ivSuccessIcon" android:layout_width="100dp" android:layout_height="100dp" android:layout_gravity="center_horizontal" android:layout_marginTop="40dp" android:src="@drawable/ic_check_circle" app:tint="@color/green_success" />

        <!-- Título -->
        <TextView android:id="@+id/tvSuccessTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center" android:text="Compra Realizada! 🎉" android:textColor="@color/white" android:textSize="26sp" android:textStyle="bold" />

        <!-- Subtítulo -->
        <TextView android:id="@+id/tvSuccessSubtitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="32dp" android:layout_marginTop="8dp" android:gravity="center" android:lineSpacingExtra="4dp" android:text="Seu pedido foi confirmado com sucesso.\nAguarde a entrega! 🚀" android:textColor="@color/text_secondary" android:textSize="14sp" />

        <!-- Card do pedido -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="16dp" android:layout_marginTop="24dp" app:cardBackgroundColor="@color/surface_dark" app:cardCornerRadius="16dp" app:cardElevation="4dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:text="Código do Pedido" android:textColor="@color/text_secondary" android:textSize="12sp" />

                <TextView android:id="@+id/tvOrderId" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:fontFamily="monospace" android:gravity="center" android:textColor="@color/orange_primary" android:textSize="20sp" android:textStyle="bold" />

                <TextView android:id="@+id/tvAffiliation" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="12sp" />

                <!-- Divisor -->
                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="@color/divider_color" />

                <!-- Lista de itens do pedido -->
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvOrderItems" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card financeiro -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="16dp" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/surface_dark" app:cardCornerRadius="16dp" app:cardElevation="4dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

              <!-- Subtotal -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Subtotal" android:textColor="@color/text_secondary" android:textSize="14sp" />

                    <TextView android:id="@+id/tvSubtotalValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold" />

                </LinearLayout>

                <!-- Frete -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Frete" android:textColor="@color/text_secondary" android:textSize="14sp" />

                    <TextView android:id="@+id/tvShippingValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold" />

                </LinearLayout>

                <!-- Impostos -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Impostos (5%)" android:textColor="@color/text_secondary" android:textSize="14sp" />

                    <TextView android:id="@+id/tvTaxValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold" />

                </LinearLayout>

                <!-- Divisor -->
                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="@color/divider_color" />

                <!-- Total -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Total Pago" android:textColor="@color/white" android:textSize="17sp" android:textStyle="bold" />

                    <TextView android:id="@+id/tvTotalValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/orange_primary" android:textSize="20sp" android:textStyle="bold" />

                </LinearLayout>

                <!-- Cupom aplicado -->
                <TextView android:id="@+id/tvCouponApplied" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:gravity="center" android:textColor="@color/green_success" android:textSize="13sp" android:textStyle="bold" android:visibility="gone" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botões de ação -->
        <com.google.android.material.button.MaterialButton android:id="@+id/btnContinueShopping" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginHorizontal="16dp" android:layout_marginTop="24dp" android:text="Continuar Comprando" android:textSize="16sp" android:textStyle="bold" app:backgroundTint="@color/orange_primary" app:cornerRadius="12dp" app:icon="@drawable/ic_bag" app:iconGravity="textStart" app:iconPadding="8dp" />

        <com.google.android.material.button.MaterialButton android:id="@+id/btnShareOrder" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:layout_marginTop="10dp" android:text="Compartilhar Pedido" android:textSize="14sp" app:cornerRadius="12dp" app:icon="@drawable/ic_share" app:iconGravity="textStart" app:iconPadding="8dp" app:strokeColor="@color/blue_share" />

        <com.google.android.material.button.MaterialButton android:id="@+id/btnRefund" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:layout_marginTop="10dp" android:text="Solicitar Reembolso" android:textSize="14sp" app:cornerRadius="12dp" app:icon="@drawable/ic_refund" app:iconGravity="textStart" app:iconPadding="8dp" app:strokeColor="@color/red_wishlist" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>


                      
